VITE_SPOTIFY_CLIENT_ID=your_spotify_client_id_here
# Local dev only — do NOT set on Vercel (production uses https://oldpod.online automatically).
# VITE_SPOTIFY_REDIRECT_URI=http://127.0.0.1:5173

# YouTube Data API v3 key (optional). Enables the free, no-login YouTube source.
# Without it, every other source still works and YouTube shows a friendly
# "needs an API key" message instead of crashing. See README → YouTube setup.
VITE_YOUTUBE_API_KEY=

# ── Apple Music (optional, premium logged-in source) ─────────────────────────
# Apple Music's secrets are read by the SERVERLESS function (api/apple-developer-
# token.ts), NOT the Vite client, so they are intentionally UNPREFIXED (no
# VITE_). Never commit the real values. Set them in Vercel → Settings →
# Environment Variables for production; for local serverless dev run `vercel dev`
# (plain `vite` does not serve /api, so Apple Music shows the graceful
# "Apple Music isn't set up yet." state until configured). See README.
# APPLE_TEAM_ID=your_10_char_team_id
# APPLE_KEY_ID=your_10_char_music_key_id
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...your .p8 contents...\n-----END PRIVATE KEY-----"
